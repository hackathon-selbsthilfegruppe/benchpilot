{
  "name": "benchpilot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace backend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:start": "./scripts/start-dev.sh",
    "dev:stop": "./scripts/stop-dev.sh",
    "remote:start": "./scripts/start-remote.sh",
    "remote:stop": "./scripts/stop-remote.sh",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "jscpd": "^4.0.9",
    "knip": "^6.7.0"
  }
}
