{
  "name": "@benchpilot/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage --coverage.include='src/protocols/**' --coverage.exclude='**/*.test.ts' --coverage.exclude='**/__fixtures__/**'"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
